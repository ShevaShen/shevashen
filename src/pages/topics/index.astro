---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { topics } from "../../data/topics.js";
---

<BaseLayout
  title="Topics — Sheva Shen"
  description="Topic index for Sheva Shen's personal knowledge hub covering agent systems, enterprise AI adoption, harness engineering, and engineering leadership."
>
  <PageHero
    eyebrow="Topics"
    title="A knowledge base for AI systems notes."
    description="Topics organize what I am learning from agent systems, enterprise AI adoption, harness engineering, OpenClaw experiments, and AI leadership questions."
  />

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {
          topics.map((topic) => (
            <a class="article-card" href={`/topics/${topic.slug}/`}>
              <p class="article-meta">{topic.notes.length} notes</p>
              <h3>{topic.title}</h3>
              <p>{topic.description}</p>
              <ul class="tag-list">
                {topic.notes.slice(0, 4).map((note) => (
                  <li>{note.title}</li>
                ))}
              </ul>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
