---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { topics } from "../../../data/topics.js";

export function getStaticPaths() {
  return topics.flatMap((topic) =>
    topic.notes.map((note) => ({
      params: { topic: topic.slug, note: note.slug },
      props: { topic, note },
    })),
  );
}

const { topic, note } = Astro.props;
---

<BaseLayout title={`${note.title} — Sheva Shen`} description={note.summary}>
  <article class="prose">
    <p class="article-meta">
      <a href={`/topics/${topic.slug}/`}>{topic.title}</a> · {note.date} · {
        note.readingTime
      }
    </p>
    <h1>{note.title}</h1>
    <p>{note.summary}</p>
    <ul class="tag-list">
      {note.tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <h2>Placeholder</h2>
    <p>This note is a placeholder. Full content will be added later.</p>
  </article>
</BaseLayout>
