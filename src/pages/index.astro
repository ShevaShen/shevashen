---
import BaseLayout from "../layouts/BaseLayout.astro";
import InitiativeCard from "../components/InitiativeCard.astro";
import { evolution, focusAreas, initiatives, site } from "../data/site.js";

const posts = Object.values(
  import.meta.glob("./writing/*.md", { eager: true }),
);
const latestPosts = posts
  .filter((post) => !post.frontmatter.draft)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.pubDate).getTime() -
      new Date(a.frontmatter.pubDate).getTime(),
  )
  .slice(0, 3);
---

<BaseLayout title={site.title} description={site.description}>
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">AI Platform Leader</p>
      <h1>Sheva Shen</h1>
      <p class="subhead">
        Building the systems that turn foundation models into business outcomes.
      </p>
      <p class="description">
        I design and lead enterprise AI platforms, agent ecosystems,
        context-aware workflows, and developer enablement programs that help
        organizations adopt AI safely and effectively.
      </p>
      <div class="cta-row">
        <a class="button primary" href="/ai-initiatives/">View AI Initiatives</a
        >
        <a class="button secondary" href="/writing/">Read Writing</a>
      </div>
      <div class="career-line" aria-label="Career evolution">
        <span>Frontend Engineer</span>
        <span>→ Staff Engineer</span>
        <span>→ AI Platform Leader</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-kicker">Current Focus</p>
        <p class="lede">
          Practical AI platform work: the infrastructure, operating models, and
          leadership patterns required to move from experiments to trusted
          organizational capability.
        </p>
      </div>
      <div class="focus-grid">
        {focusAreas.map((area) => <div class="focus-item">{area}</div>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-kicker">Featured AI Initiatives</p>
        <h2>Systems around AI, not just AI features.</h2>
      </div>
      <div class="card-grid">
        {
          initiatives.map((initiative) => (
            <InitiativeCard initiative={initiative} />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-kicker">Career Evolution</p>
        <p class="lede">
          A path from visual systems and frontend execution into platform
          strategy, staff-level leadership, and enterprise AI adoption.
        </p>
      </div>
      <div class="timeline">
        {
          evolution.map((step, index) => (
            <div class="timeline-step">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{step}</strong>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-kicker">Writing</p>
        <h2>Notes on enterprise AI, agent engineering, and leadership.</h2>
      </div>
      <div class="card-grid">
        {
          latestPosts.map((post) => (
            <article class="article-card">
              <p class="article-meta">
                {new Date(post.frontmatter.pubDate).getFullYear()}
              </p>
              <h3>
                <a href={post.url}>{post.frontmatter.title}</a>
              </h3>
              <p>{post.frontmatter.description}</p>
            </article>
          ))
        }
      </div>
      <div class="link-row">
        <a class="button" href="/writing/">All Writing</a>
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <div class="section-header">
        <p class="section-kicker">Contact</p>
        <p class="lede">
          Available for conversations around AI platform strategy, enterprise
          adoption, engineering leadership, advisory work, and speaking.
        </p>
      </div>
      <a class="button" href="/contact/">Get in touch</a>
    </div>
  </section>
</BaseLayout>
