---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";

const posts = Object.values(import.meta.glob("./*.md", { eager: true }));
const articles = posts
  .filter((post) => !post.frontmatter.draft)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.pubDate).getTime() -
      new Date(a.frontmatter.pubDate).getTime(),
  );
---

<BaseLayout
  title="Writing — Sheva Shen"
  description="Writing on AI strategy, enterprise AI, agent engineering, engineering leadership, and developer productivity."
>
  <PageHero
    eyebrow="Writing"
    title="Thought leadership on enterprise AI systems."
    description="Notes and essays on AI strategy, agent engineering, developer productivity, governance, and platform leadership."
  />

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {
          articles.map((post) => (
            <article class="article-card">
              <p class="article-meta">
                {new Date(post.frontmatter.pubDate).toLocaleDateString("en", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })}
              </p>
              <h3>
                <a href={post.url}>{post.frontmatter.title}</a>
              </h3>
              <p>{post.frontmatter.description}</p>
              <ul class="tag-list">
                {post.frontmatter.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
