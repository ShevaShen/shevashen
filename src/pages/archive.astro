---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const archived = [
  {
    title: "Legacy Frontend Projects",
    text: "Earlier client and product work from the Gatsby portfolio era, including marketing portals, community tools, and product redesigns.",
  },
  {
    title: "Design & Photography",
    text: "Creative background preserved as context for product taste, visual systems, and communication craft.",
  },
  {
    title: "Fitness & Personal Writing",
    text: "Older personal essays and non-AI writing moved out of the primary navigation to keep the new positioning focused.",
  },
];
---

<BaseLayout
  title="Archive — Sheva Shen"
  description="Archived legacy portfolio material from earlier frontend, design, photography, and personal writing eras."
>
  <PageHero
    eyebrow="Archive"
    title="Legacy work, preserved but not foregrounded."
    description="Older portfolio projects, frontend work, technology lists, and legacy blog posts belong here so the main site can stay focused on the current learning journey into AI."
  />

  <section class="section">
    <div class="container">
      <div class="background-list">
        {
          archived.map((item) => (
            <article class="background-item">
              <strong>{item.title}</strong>
              <p>{item.text}</p>
            </article>
          ))
        }
      </div>
      <div class="link-row">
        <a class="button" href="/about/">Read the evolution story</a>
      </div>
    </div>
  </section>
</BaseLayout>
